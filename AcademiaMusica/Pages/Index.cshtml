@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="page-heading">
    <h2>Panel de Control</h2>
    <div class="heading-line"></div>
</div>

<div class="dash-grid">

    <a href="/Alumnos" class="dash-card card-green">
        <span class="card-emoji">🎓</span>
        <h5>Alumnos</h5>
        <p>Gestión de alumnos de la academia</p>
        <span class="dash-btn">Gestionar</span>
    </a>

    <a href="/Profesores" class="dash-card card-purple">
        <span class="card-emoji">👨‍🏫</span>
        <h5>Profesores</h5>
        <p>Gestión de profesores y tarifas</p>
        <span class="dash-btn">Gestionar</span>
    </a>

    <a href="/Instrumentos" class="dash-card card-blue">
        <span class="card-emoji">🎸</span>
        <h5>Instrumentos</h5>
        <p>Gestión de instrumentos musicales</p>
        <span class="dash-btn">Gestionar</span>
    </a>

</div>
