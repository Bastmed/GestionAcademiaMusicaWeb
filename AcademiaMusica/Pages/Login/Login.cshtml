@page
@model AcademiaMusica.Pages.Login.LoginModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body p-4">
                <h4 class="card-title text-center mb-4">🎵 Iniciar Sesión</h4>

                @if (!string.IsNullOrEmpty(Model.MensajeError))
                {
                    <div class="alert alert-danger">@Model.MensajeError</div>
                }

                <form method="post">
                    <div class="form-group mb-3">
                        <label>Usuario</label>
                        <input name="NombreUsuario" class="form-control" required autofocus />
                    </div>
                    <div class="form-group mb-4">
                        <label>Contraseña</label>
                        <input name="Contrasena" type="password" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-success w-100">Entrar</button>
                </form>

                <div class="text-center mt-3">
                    <a asp-page="/Login/Registro">¿No tienes cuenta? Regístrate</a>
                </div>
            </div>
        </div>
    </div>
</div>
