@page
@model AcademiaMusica.Pages.Profesores.IndexModel
@{
    ViewData["Title"] = "Gestión de Profesores";
}

<div class="page-heading">
    <h2> Profesores</h2>
    <div class="heading-line"></div>
</div>

<div class="card-dark">
    <div class="table-toolbar">
        @if (Model.PuedeModificar)
        {
            <a asp-page="./Crear" class="btn-accent-purple">+ Nuevo Profesor</a>
        }
        <div class="search-bar" style="width:280px">
            <span class="search-icon"></span>
            <input type="text" placeholder="Buscar profesor..." oninput="filtrarTabla(this.value)" />
        </div>
    </div>

    <table class="table-dark-custom" id="tablaProfesores">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Teléfono</th>
                <th>Email</th>
                <th>Especialidad</th>
                <th>Tarifa/Hora</th>
                <th>Con IVA</th>
                <th>Estado</th>
                @if (Model.PuedeModificar)
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Profesores)
            {
                <tr>
                    <td>@p.NombreProfesor</td>
                    <td>@p.ApellidoProfesor</td>
                    <td>@p.TelefonoProfesor</td>
                    <td>@p.EmailProfesor</td>
                    <td>@p.Especialidad</td>
                    <td>$@p.TarifaHora.ToString("N0")</td>
                    <td>$@p.TarifaConIVA.ToString("N0")</td>
                    <td>
                        @if (p.ActivoProfesor)
                        {
                            <span class="badge-activo si">Activo</span>
                        }
                        else
                        {
                            <span class="badge-activo no">Inactivo</span>
                        }
                    </td>
                    @if (Model.PuedeModificar)
                    {
                        <td>
                            <a asp-page="./Editar" asp-route-id="@p.IdProfesor" class="btn-edit">✏ Editar</a>
                            <form method="post" asp-page-handler="Eliminar" asp-route-id="@p.IdProfesor" style="display:inline">
                                <button type="submit" class="btn-delete"
                                        onclick="return confirm('¿Eliminar a @p.NombreProfesor?')">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function filtrarTabla(q) {
            q = q.toLowerCase();
            document.querySelectorAll('#tablaProfesores tbody tr').forEach(tr => {
                tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>
}
