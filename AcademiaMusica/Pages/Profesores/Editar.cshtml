@page "{id:int}"
@model AcademiaMusica.Pages.Profesores.EditarModel
@{
    ViewData["Title"] = "Editar Profesor";
    var especialidades = new[]
    {
        "Guitarra Clásica","Guitarra Eléctrica","Bajo Eléctrico","Piano","Violín",
        "Violoncello","Contrabajo","Flauta Traversa","Clarinete","Saxofón",
        "Trompeta","Trombón","Percusión Clásica","Batería","Arpa",
        "Canto Lírico","Canto Popular","Charango","Quena",
        "Teoría Musical y Solfeo","Composición","Dirección Coral"
    };

    var seleccionadas = (Model.Profesor?.Especialidad ?? "")
        .Split(',')
        .Select(s => s.Trim())
        .Where(s => !string.IsNullOrEmpty(s))
        .ToHashSet();
}

<div class="page-heading">
    <h2>Editar Profesor</h2>
    <div class="heading-line"></div>
</div>

<div class="card-dark">
    <form method="post">
        <input type="hidden" asp-for="Profesor.IdProfesor" />
        <div class="form-grid">

            <div class="form-field">
                <label>Nombre</label>
                <input asp-for="Profesor.NombreProfesor" required />
            </div>

            <div class="form-field">
                <label>Apellido</label>
                <input asp-for="Profesor.ApellidoProfesor" required />
            </div>

            <div class="form-field">
                <label>Teléfono</label>
                <input asp-for="Profesor.TelefonoProfesor" />
            </div>

            <div class="form-field">
                <label>Email</label>
                <input asp-for="Profesor.EmailProfesor" type="email" />
            </div>

            <div class="form-field">
                <label>Tarifa por Hora ($)</label>
                <input asp-for="Profesor.TarifaHora" type="number" min="1" id="tarifaInput" required />
                <div class="tarifa-preview" id="tarifaPreview">Con IVA (19%): calculando...</div>
            </div>

            <div class="form-field">
                <label>Estado</label>
                <div class="checkbox-row">
                    <input asp-for="Profesor.ActivoProfesor" type="checkbox" />
                    <span>Profesor activo</span>
                </div>
            </div>

        </div>

     
        <div style="margin-top:24px;">
            <label style="font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--text-label);">
                Especialidades <span style="color:var(--text-muted);font-size:11px;">(Máx. 7)</span>
            </label>
            <div id="especialidades-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-top:12px;">
                @foreach (var esp in especialidades)
                {
                    var estaSeleccionada = seleccionadas.Contains(esp);
                    <label style="display:flex;align-items:center;gap:8px;padding:8px 12px;
                        background:@(estaSeleccionada ? "rgba(124,77,255,0.1)" : "rgba(255,255,255,0.03)");
                        border:1px solid @(estaSeleccionada ? "rgba(124,77,255,0.6)" : "rgba(255,255,255,0.07)");
                        border-radius:6px;cursor:pointer;transition:all 0.15s;" class="esp-label">
                        <input type="checkbox" name="especialidadesSeleccionadas" value="@esp"
                               style="accent-color:var(--accent-purple);width:15px;height:15px;"
                               onchange="limitarEspecialidades(this)"
                        @(estaSeleccionada ? "checked" : "") />
                        <span style="font-size:13px;color:var(--text-primary);">@esp</span>
                    </label>
                }
            </div>
            <input type="hidden" name="Profesor.Especialidad" id="especialidadFinal" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-accent-purple" onclick="prepararEspecialidades()">✔ Guardar Cambios</button>
            <a asp-page="./Index" class="btn-outline-dim">✕ Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Calcular IVA
        const tarifaInput = document.getElementById('tarifaInput');
        const preview = document.getElementById('tarifaPreview');

        function updatePreview() {
            const v = parseFloat(tarifaInput.value) || 0;
            preview.textContent = 'Con IVA (19%): $' + Math.round(v * 1.19).toLocaleString('es-CL');
        }
        tarifaInput?.addEventListener('input', updatePreview);
        updatePreview();

        
        function limitarEspecialidades(cb) {
            const checks = document.querySelectorAll('input[name="especialidadesSeleccionadas"]:checked');
            if (checks.length > 7) {
                cb.checked = false;
                alert('Máximo 7 especialidades permitidas.');
            }
            document.querySelectorAll('.esp-label').forEach(label => {
                const input = label.querySelector('input');
                label.style.borderColor = input.checked ? 'rgba(124,77,255,0.6)' : 'rgba(255,255,255,0.07)';
                label.style.background = input.checked ? 'rgba(124,77,255,0.1)' : 'rgba(255,255,255,0.03)';
            });
        }

      
        function prepararEspecialidades() {
            const checks = document.querySelectorAll('input[name="especialidadesSeleccionadas"]:checked');
            const valores = Array.from(checks).map(c => c.value);
            document.getElementById('especialidadFinal').value = valores.join(', ');
        }
    </script>
}
