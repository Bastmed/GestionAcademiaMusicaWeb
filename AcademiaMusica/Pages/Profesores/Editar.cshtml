@page "{id:int}"
@model AcademiaMusica.Pages.Profesores.EditarModel
@{
    ViewData["Title"] = "Editar Profesor";
}

<div class="page-heading">
    <h2> Editar Profesor</h2>
    <div class="heading-line"></div>
</div>

<div class="card-dark">
    <form method="post">
        <input type="hidden" asp-for="Profesor.IdProfesor" />
        <div class="form-grid">

            <div class="form-field">
                <label> Nombre</label>
                <input asp-for="Profesor.NombreProfesor" required />
            </div>

            <div class="form-field">
                <label> Apellido</label>
                <input asp-for="Profesor.ApellidoProfesor" required />
            </div>

            <div class="form-field">
                <label> Teléfono</label>
                <input asp-for="Profesor.TelefonoProfesor" />
            </div>

            <div class="form-field">
                <label> Email</label>
                <input asp-for="Profesor.EmailProfesor" type="email" />
            </div>

            <div class="form-field">
                <label> Especialidad</label>
                <select asp-for="Profesor.Especialidad">
                    <option value="">-- Selecciona --</option>
                    <option>Guitarra Clásica</option>
                    <option>Guitarra Eléctrica</option>
                    <option>Bajo Eléctrico</option>
                    <option>Piano</option>
                    <option>Violín</option>
                    <option>Violoncello</option>
                    <option>Contrabajo</option>
                    <option>Flauta Traversa</option>
                    <option>Clarinete</option>
                    <option>Saxofón</option>
                    <option>Trompeta</option>
                    <option>Trombón</option>
                    <option>Percusión Clásica</option>
                    <option>Batería</option>
                    <option>Arpa</option>
                    <option>Canto Lírico</option>
                    <option>Canto Popular</option>
                    <option>Charango</option>
                    <option>Quena</option>
                    <option>Teoría Musical y Solfeo</option>
                    <option>Composición</option>
                    <option>Dirección Coral</option>
                </select>
            </div>

            <div class="form-field">
                <label> Tarifa por Hora ($)</label>
                <input asp-for="Profesor.TarifaHora" type="number" min="1" id="tarifaInput" required />
                <div class="tarifa-preview" id="tarifaPreview">Con IVA (19%): calculando...</div>
            </div>

            <div class="form-field">
                <label>Estado</label>
                <div class="checkbox-row">
                    <input asp-for="Profesor.ActivoProfesor" type="checkbox" />
                    <span>Profesor activo</span>
                </div>
            </div>

        </div>

        <div class="form-actions">
            <button type="submit" class="btn-accent-purple">✔ Guardar Cambios</button>
            <a asp-page="./Index" class="btn-outline-dim">✕ Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const tarifaInput = document.getElementById('tarifaInput');
        const preview = document.getElementById('tarifaPreview');

        function updatePreview() {
            const v = parseFloat(tarifaInput.value) || 0;
            preview.textContent = 'Con IVA (19%): $' + Math.round(v * 1.19).toLocaleString('es-CL');
        }

        tarifaInput?.addEventListener('input', updatePreview);
        updatePreview();
    </script>
}
