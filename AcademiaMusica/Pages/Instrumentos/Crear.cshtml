@page
@model AcademiaMusica.Pages.Instrumentos.CrearModel
@{
    ViewData["Title"] = "Crear Instrumento";
}

<h2>Crear Instrumento</h2>

<form method="post">
    <div class="form-group mb-3">
        <label asp-for="Instrumento.NombreInstrumento" class="control-label">Nombre</label>
        <input asp-for="Instrumento.NombreInstrumento" class="form-control" required />
    </div>
    <div class="form-group mb-3">
        <label asp-for="Instrumento.Categoria" class="control-label">Categoría</label>
        <select asp-for="Instrumento.Categoria" class="form-control" required>
            <option value="">-- Selecciona --</option>
            <option>Cuerda Frotada</option>
            <option>Cuerda Pulsada</option>
            <option>Cuerda Percutida</option>
            <option>Viento Madera</option>
            <option>Viento Metal</option>
            <option>Percusión</option>
            <option>Teclas</option>
            <option>Electrónico</option>
            <option>Folclórico</option>
        </select>
    </div>
    <div class="form-group mb-3">
        <label asp-for="Instrumento.Marca" class="control-label">Marca</label>
        <select asp-for="Instrumento.Marca" class="form-control">
            <option value="">-- Selecciona --</option>
            <option>Yamaha</option>
            <option>Gibson</option>
            <option>Fender</option>
            <option>Roland</option>
            <option>Steinway & Sons</option>
            <option>Kawai</option>
            <option>Pearl</option>
            <option>Casio</option>
            <option>Korg</option>
            <option>Ibanez</option>
            <option>PRS (Paul Reed Smith)</option>
            <option>Martin</option>
            <option>Taylor</option>
            <option>Selmer</option>
            <option>Bach</option>
            <option>Gemeinhardt</option>
            <option>Buffet Crampon</option>
            <option>Zildjian</option>
            <option>Meinl</option>
            <option>DW (Drum Workshop)</option>
        </select>
    </div>
    <div class="form-group mb-3">
        <label asp-for="Instrumento.Estado" class="control-label">Estado</label>
        <select asp-for="Instrumento.Estado" class="form-control" required>
            <option value="">-- Selecciona --</option>
            <option>Disponible</option>
            <option>En uso</option>
            <option>En mantenimiento</option>
            <option>Deteriorado</option>
            <option>De baja</option>
        </select>
    </div>

    <input type="submit" value="Crear" class="btn btn-success" />
    <a asp-page="./Index" class="btn btn-secondary">Cancelar</a>
</form>
