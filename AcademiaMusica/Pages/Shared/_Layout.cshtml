<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Academia de Música</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">🎵 Academia Kong Egg</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (Context.Session.GetString("usuario") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Alumnos/Index">Alumnos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Profesores/Index">Profesores</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Instrumentos/Index">Instrumentos</a>
                            </li>
                        }
                    </ul>
                    @if (Context.Session.GetString("usuario") != null)
                    {
                        <span class="navbar-text text-light me-3">
                            👤 @Context.Session.GetString("usuario")
                        </span>
                        <a asp-page="/Login/Logout" class="btn btn-outline-light btn-sm">Cerrar sesión</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - Academia de Música Kong Egg
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
