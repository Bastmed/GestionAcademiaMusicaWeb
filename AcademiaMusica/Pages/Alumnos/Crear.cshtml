@page
@model AcademiaMusica.Pages.Alumnos.CrearModel
@{
    ViewData["Title"] = "Crear Alumno";
}

<div class="page-heading">
    <h2> Nuevo Alumno</h2>
    <div class="heading-line"></div>
</div>

<div class="card-dark">
    <form method="post">
        <div class="form-grid">

            <div class="form-field">
                <label> Nombre</label>
                <input asp-for="Alumno.NombreAlumno" placeholder="Ej: María" required />
            </div>

            <div class="form-field">
                <label> Apellido</label>
                <input asp-for="Alumno.ApellidoAlumno" placeholder="Ej: González" required />
            </div>

            <div class="form-field">
                <label> Fecha de Nacimiento</label>
                <input asp-for="Alumno.FechaNacimiento" type="date" required />
            </div>

            <div class="form-field">
                <label> Email</label>
                <input asp-for="Alumno.EmailAlumno" type="email" placeholder="usuario@email.com" required />
            </div>

            <div class="form-field">
                <label>Teléfono</label>
                <input asp-for="Alumno.TelefonoAlumno" placeholder="Ej: +56 912345678" required />
            </div>

            <div class="form-field">
                <label>Estado</label>
                <div class="checkbox-row">
                    <input asp-for="Alumno.ActivoAlumno" type="checkbox" checked />
                    <span>Alumno activo</span>
                </div>
            </div>

        </div>

        <div class="form-actions">
            <button type="submit" class="btn-accent-green">✔ Registrar Alumno</button>
            <a asp-page="./Index" class="btn-outline-dim">✕ Cancelar</a>
        </div>
    </form>
</div>
