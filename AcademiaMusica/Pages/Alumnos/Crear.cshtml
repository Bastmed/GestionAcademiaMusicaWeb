@page
@model AcademiaMusica.Pages.Alumnos.CrearModel
@{
    ViewData["Title"] = "Crear Alumno";
}
<div class="container mt-4">
    <h2>Crear Alumno</h2>

    <form method="post">
        <div class="form-group mb-3">
            <label asp-for="Alumno.NombreAlumno" class="control-label">Nombre</label>
            <input asp-for="Alumno.NombreAlumno" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label asp-for="Alumno.ApellidoAlumno" class="control-label">Apellido</label>
            <input asp-for="Alumno.ApellidoAlumno" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label asp-for="Alumno.FechaNacimiento" class="control-label">Fecha de Nacimiento</label>
            <input asp-for="Alumno.FechaNacimiento" type="date" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label asp-for="Alumno.TelefonoAlumno" class="control-label">Teléfono</label>
            <input asp-for="Alumno.TelefonoAlumno" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label asp-for="Alumno.EmailAlumno" class="control-label">Email</label>
            <input asp-for="Alumno.EmailAlumno" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <div class="form-check">
                <input asp-for="Alumno.ActivoAlumno" class="form-check-input" />
                <label asp-for="Alumno.ActivoAlumno" class="form-check-label">Activo</label>
            </div>
        </div>
        <div class="form-group">
            <input type="submit" value="Crear" class="btn btn-success" />
        </div>
    </form>

    <div class="mt-3">
        <a asp-page="./Index">Volver a la lista</a>
    </div>
</div>

