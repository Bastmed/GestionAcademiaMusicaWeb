@page
@model AcademiaMusica.Pages.Alumnos.IndexModel
@{
    ViewData["Title"] = "Gestión de Alumnos";
}

<h2>Gestión de Alumnos</h2>

<a asp-page="./Crear" class="btn btn-success mb-3">+ Nuevo Alumno</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Teléfono</th>
            <th>Email</th>
            <th>Fecha Nac.</th>
            <th>Activo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model.Alumnos)
        {
            <tr>
                <td>@a.NombreAlumno</td>
                <td>@a.ApellidoAlumno</td>
                <td>@a.TelefonoAlumno</td>
                <td>@a.EmailAlumno</td>
                <td>@(a.FechaNacimiento.HasValue ? a.FechaNacimiento.Value.ToString("dd/MM/yyyy") : "-")</td>
                <td>@(a.ActivoAlumno ? "Sí" : "No")</td>
                <td>
                    <a asp-page="./Editar" asp-route-id="@a.IdAlumno" class="btn btn-warning btn-sm">Editar</a>
                    <form method="post" asp-page-handler="Eliminar" asp-route-id="@a.IdAlumno" style="display:inline">
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('¿Estás seguro de eliminar a @a.NombreAlumno?')">
                            Eliminar
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

